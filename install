#!/usr/bin/env zsh
# Main install script to setup links to dotfiles that are in this repo. This can be called
# locally after cloning the repo or through curling the file and pipeing it to bash.

declare -A confLinks=(
	[config/git]="$HOME/.config/git" 
	[config/tmux]="$HOME/.config/tmux" 
	[config/nvim]="$HOME/.config/nvim"
	[config/homebrew]="$HOME/.config/homebrew"
	[config/claude/CLAUDE.md]="$HOME/.config/claude/CLAUDE.md"
	[config/claude/RTK.md]="$HOME/.config/claude/RTK.md"
	[config/claude/settings.json]="$HOME/.config/claude/settings.json"
	[config/claude/statusline-command.sh]="$HOME/.config/claude/statusline-command.sh"
	[config/claude/hooks]="$HOME/.config/claude/hooks"
	[config/zsh]="$HOME/.config/zsh"
	[config/ssh/config]="$HOME/.ssh/config"
	[config/zsh/zshrc]="$HOME/.zshrc"
	[config/bin/dup]="$HOME/.local/bin/dup"
)

# Required directories that just need to exist for other actions or for the config
# to work correctly
declare -a defaultDirs=(
	"$HOME/.ssh"
	"$HOME/workspace"
	# Enure XDG folders are setup
	"$HOME/.config"
	"$HOME/.config/claude"
 	"$HOME/.local"
	"$HOME/.cache"
	# Local Bin folder for linked commands
	"$HOME/.local/bin"
	# XDG Runtime Directory
	"$HOME/.local/run"
	# History File Locations
	"$HOME/.local/share/less" 
	"$HOME/.local/share/zsh"
)
                                                                
echo "‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēó"
echo "‚ēĎ‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēó‚ēĎ"
echo "‚ēĎ‚ēĎ   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó   ‚ēĎ‚ēĎ"
echo "‚ēĎ‚ēĎ   ‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ   ‚ēĎ‚ēĎ"
echo "‚ēĎ‚ēĎ   ‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ   ‚ēĎ‚ēĎ"
echo "‚ēĎ‚ēĎ   ‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēĚ   ‚ēĎ‚ēĎ"
echo "‚ēĎ‚ēĎ   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēó   ‚ēĎ‚ēĎ"
echo "‚ēĎ‚ēĎ   ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ    ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ     ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ   ‚ēĎ‚ēĎ"
echo "‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēĎ"
echo "‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ"

echo "=== resetting env ==="
for value in "${confLinks[@]}"; do 
	echo "  ūüĒ• $value"
	rm -rf "$value";
done
echo "‚úÖ clean."

echo "=== creating default directories ==="
for item in "${defaultDirs[@]}"; do
	echo "  ūüóāÔłŹ $item"
	mkdir -p "$item"
done
# Create gitconfig.local so that our gitconfig will not break.
touch $HOME/.gitconfig.local
echo "‚úÖ default directories in place."

# Ensure we have our ssh key setup if this is the first time.
if [ ! -f "$HOME/.ssh/id_rsa" ]; then
	echo "==== generating a new ssh key"
	mkdir -p $HOME/.ssh
	read -r "ssh_email?Enter your email for the SSH key: "
	ssh-keygen -t rsa -b 4096 -C "$ssh_email"
	eval "$(ssh-agent -s)"
	ssh-add --apple-use-keychain $HOME/.ssh/id_rsa
	cat $HOME/.ssh/id_rsa.pub | pbcopy
	open "https://github.com/settings/keys"
	read -p "New ssh key is in clipboard add it to github and press enter to continue ..."
fi

# This might be a call from curl pipes to bash so we might not have the repo yet.
if [ ! -d "$HOME/workspace/dotfiles" ]; then
	echo "=== Cloning dotfiles"
	mkdir -p $HOME/workspace
	git clone git@github.com:tanema/dotfiles.git $HOME/workspace/dotfiles
fi

echo "=== linking config files ==="
for key value in "${(@kv)confLinks}"; do 
	echo "  ūüĆä Linking $HOME/workspace/dotfiles/$key => $value"
	ln -sf "$HOME/workspace/dotfiles/$key" "$value"
done
echo "‚úÖ config files linked"

echo "=== ensuring xcode is setup ==="
xcode-select --install 2>/dev/null || true
echo "‚úÖ command line tools installed"

echo "=== installing homebrew ==="
if ! command -v brew >/dev/null 2>&1; then
	sudo true
	NONINTERACTIVE=1 curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install.sh | bash
	eval "$(/opt/homebrew/bin/brew shellenv)"
fi
echo "‚úÖ Homebrew installed"

# Calling our linked update command it will install the tools we need for following
# commands
$HOME/.local/bin/dup

echo "=== setting up GPG ==="
GPG_COUNT=$(gpg --list-keys --with-colons 2>/dev/null | grep -c '^pub:')
if [[ -z "$GPG_COUNT" ]]; then
	gpg --default-new-key-algo rsa4096 --gen-key
	gpg --armor --export $(gpg --list-keys --with-colons --with-fingerprint | awk -F: '/^fpr:/ { print $10 }' | tail -n 1) | pbcopy
	open "https://github.com/settings/keys"
	read -p "New gpg key is in clipboard add it to github and press enter to continue ..."
fi
echo "‚úÖ gpg setup complete"
