#!/usr/bin/env zsh


echo '╔──────────────────────────────────────────────────────────────────╗'
echo '│  __  __   ______    ______    ________    _________   ______     │'
echo '│/_/\/_/\  /_____/\  /_____/\  /_______/\  /________/\ /_____/\    │'
echo '│\:\ \:\ \ \:::_ \ \ \:::_ \ \ \::: _  \ \ \__.::.__\/ \::::_\/_   │'
echo '│ \:\ \:\ \ \:(_) \ \ \:\ \ \ \ \::(_)  \ \   \::\ \    \:\/___/\  │'
echo '│  \:\ \:\ \ \: ___\/  \:\ \ \ \ \:: __  \ \   \::\ \    \::___\/_ │'
echo '│   \:\_\:\ \ \ \ \     \:\/.:| | \:.\ \  \ \   \::\ \    \:\____/\│'
echo '│    \_____\/  \_\/      \____/_/  \__\/\__\/    \__\/     \_____\/│'
echo '╚──────────────────────────────────────────────────────────────────╝'

DOTFILES_DIR="$HOME/workspace/dotfiles"

echo "=== Dotfiles repo ==="
git -C "$DOTFILES_DIR" fetch --quiet
if [[ "$(git -C "$DOTFILES_DIR" rev-parse @)" != "$(git -C "$DOTFILES_DIR" rev-parse @{u})" ]]; then
	if [[ -n "$(git -C "$DOTFILES_DIR" status --porcelain)" ]]; then
		echo "⚠️  dotfiles repo is behind remote, commit or stash local changes before updating"
	else
		echo "⬇️  pulling latest dotfiles"
		git -C "$DOTFILES_DIR" pull --ff-only
	fi
else
	echo "✅ dotfiles up to date."
fi

echo "=== Brew Bundle ==="
/opt/homebrew/bin/brew update
/opt/homebrew/bin/brew bundle --global --quiet
echo "✅ homebrew bundle updated."

echo "=== NPM deps ==="
"$(brew --prefix)/bin/npm" install -g --silent svelte-language-server
echo "✅ npm packages updated."
