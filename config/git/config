[core]
  editor = nvim
  commitGraph = true
[color]
  ui = true
[init]
  defaultBranch = main
[column]
  ui = auto 
[help]
  autocorrect = 5
[include]
	# Allow computer settings so each computer can have different emails and signing keys
  path = ~/.gitconfig.local
[user]
  name = Tim Anema
[diff]
  tool = nvim -d
  algorithm = histogram
  colorMoved = dimmed-zebra
  colorMovedWs = ignore-space-change
  mnemonicPrefix = true
  renames = true
	context = 10
[push]
  default = current
  autoSetupRemote = true
  followTags = true
[pull]
  rebase = true
  prune = true
  default = current
[merge]
  conflictstyle = zdiff3
[rerere]
  enabled = true
  autoupdate = true
[fetch]
  prune = true
  pruneTags = true
  all = true
[commit]
  # gpgsign = true
  verbose = true
[rebase]
  autoStash = true
  autoSquash = true
  updateRefs = true
[gpg]
  program = gpg
[url "ssh://git@github.com/"]
  insteadOf = https://github.com/
[url "ssh://git@gitlab.com/"]
  insteadOf = https://gitlab.com/
[protocol]
  version = 2
[gc]
  writeCommitGraph = true
[branch]
  sort = -committerdate
[tag]
  sort = version:refname
